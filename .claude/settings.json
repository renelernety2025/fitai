{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm install:*)",
      "Bash(npm run:*)",
      "Bash(npm test:*)",
      "Bash(npm ci:*)",
      "Bash(npx:*)",
      "Bash(pnpm install:*)",
      "Bash(pnpm run:*)",
      "Bash(pnpm add:*)",
      "Bash(pnpm --filter:*)",
      "Bash(node:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push origin main)",
      "Bash(git push origin:*)",
      "Bash(git pull:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git fetch:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(git checkout:*)",
      "Bash(git restore:*)",
      "Bash(git reset --hard origin/*)",
      "Bash(git stash:*)",
      "Bash(cat:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(echo:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(which:*)",
      "Bash(pwd)",
      "Bash(jq:*)",
      "Bash(rm -rf apps/mobile/node_modules)",
      "Bash(rm -rf node_modules)",
      "Bash(rm -rf /tmp/*)",
      "Bash(rm /tmp/*)",
      "Bash(k6 run:*)",
      "Bash(brew install:*)",
      "Bash(aws sts get-caller-identity:*)",
      "Bash(aws ecs describe:*)",
      "Bash(aws ecs list:*)",
      "Bash(aws ecs run-task:*)",
      "Bash(aws ecs update-service:*)",
      "Bash(aws ecs register-task-definition:*)",
      "Bash(aws ecs wait:*)",
      "Bash(aws codebuild list:*)",
      "Bash(aws codebuild batch-get:*)",
      "Bash(aws codebuild start-build:*)",
      "Bash(aws cloudwatch:*)",
      "Bash(aws logs:*)",
      "Bash(aws elbv2:*)",
      "Bash(aws s3 ls:*)",
      "Bash(aws s3api get-bucket-cors:*)",
      "Bash(aws s3api put-bucket-cors:*)",
      "Bash(aws s3api get-bucket-policy:*)",
      "Bash(aws s3api get-public-access-block:*)",
      "Bash(aws secretsmanager describe-secret:*)",
      "Bash(aws secretsmanager create-secret:*)",
      "Bash(aws iam get-role:*)",
      "Bash(aws iam list-role-policies:*)",
      "Bash(aws iam get-role-policy:*)",
      "Bash(aws iam put-role-policy:*)",
      "Bash(aws iam create-role:*)",
      "Bash(aws iam create-open-id-connect-provider:*)",
      "Bash(aws iam list-attached-role-policies:*)",
      "Bash(aws application-autoscaling:*)",
      "Bash(aws sns create-topic:*)",
      "Bash(aws sns subscribe:*)",
      "Bash(aws sns list-subscriptions-by-topic:*)",
      "Bash(docker-compose:*)",
      "Bash(npx eas:*)",
      "Bash(npx expo:*)",
      "Bash(npx prisma:*)",
      "Bash(npx next:*)",
      "Bash(npx nest:*)",
      "Bash(npx tsc:*)"
    ],
    "deny": [
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/*)",
      "Bash(rm -rf $HOME/*)",
      "Bash(chmod 777:*)",
      "Bash(chmod -R 777:*)",
      "Bash(eval:*)",
      "Bash(exec:*)",
      "Bash(sudo:*)",
      "Bash(su:*)",
      "Bash(dd:*)",
      "Bash(mkfs:*)",
      "Bash(:(){:|:&};:)",
      "Bash(nc:*)",
      "Bash(ncat:*)",
      "Bash(telnet:*)",
      "Bash(ssh:*)",
      "Bash(scp:*)",
      "Bash(rsync:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push origin main --force:*)",
      "Bash(git reset --hard HEAD~:*)",
      "Bash(npm publish:*)",
      "Bash(pnpm publish:*)",
      "Bash(aws iam delete:*)",
      "Bash(aws secretsmanager delete-secret:*)",
      "Bash(aws rds delete:*)",
      "Bash(aws ecs delete-cluster:*)",
      "Bash(aws ecs delete-service:*)",
      "Bash(aws s3 rb:*)",
      "Bash(aws s3 rm s3://:*)",
      "Bash(aws cloudformation delete-stack:*)",
      "Bash(aws ec2 terminate-instances:*)"
    ],
    "defaultMode": "ask"
  },
  "enableAllProjectMcpServers": false,
  "enabledMcpjsonServers": [],
  "autoMemoryEnabled": true,
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/notify.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/compact-reminder.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/protect-files.sh"
          }
        ]
      }
    ]
  }
}
