}

model RoutineItem {
  id            String          @id @default(uuid())
  routineId     String
  type          RoutineItemType
  timing        RoutineTime
  referenceId   String?
  referenceName String
  notes         String?
  sortOrder     Int             @default(0)

  routine Routine @relation(fields: [routineId], references: [id], onDelete: Cascade)

  @@index([routineId])
}

model Bundle {
  id          String   @id @default(uuid())
  creatorId   String
  name        String
  description String?
  items       Json     @default("[]")
  priceXP     Int      @default(0)
  isPublic    Boolean  @default(true)
  giftable    Boolean  @default(true)
  createdAt   DateTime @default(now())

  creator   User             @relation(fields: [creatorId], references: [id])
  purchases BundlePurchase[]

  @@index([creatorId])
}

model BundlePurchase {
  id          String   @id @default(uuid())
  bundleId    String
  userId      String
  purchasedAt DateTime @default(now())

  bundle Bundle @relation(fields: [bundleId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@unique([bundleId, userId])
  @@index([userId])
}

model DailyQuestCompletion {
  id        String   @id @default(uuid())
  userId    String
  questId   String
  date      DateTime @db.Date
  xpAwarded Int
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, questId, date])
  @@index([userId, date])
}

model Wishlist {
  id       String           @id @default(uuid())
  userId   String
  itemType WishlistItemType
  itemId   String
  addedAt  DateTime         @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, itemType, itemId])
  @@index([userId])
}

model PlanTrial {
  id                  String      @id @default(uuid())
  userId              String
  planId              String
  startDate           DateTime
  endDate             DateTime
  status              TrialStatus @default(TRIAL_ACTIVE)
  convertedToPurchase Boolean     @default(false)
  createdAt           DateTime    @default(now())

  user User        @relation(fields: [userId], references: [id])
  plan WorkoutPlan @relation(fields: [planId], references: [id])

  @@index([userId, status])
}

// ── Cross-Industry Features: Phase 5 — Exclusivity & Brand ──

enum DropCategory {
  DROP_WORKOUT_PLAN
  DROP_CHALLENGE
  DROP_BOSS_FIGHT
  DROP_BADGE
  DROP_EXPERIENCE
}

enum VIPTier {
  GOLD
  PLATINUM
  DIAMOND
}

model Drop {
  id                  String       @id @default(uuid())
  name                String
  description         String
  totalEditions       Int
  remainingEditions   Int
  releaseDate         DateTime
  endDate             DateTime
  priceXP             Int          @default(0)
  exclusiveRewardType String
  exclusiveRewardData Json         @default("{}")
  category            DropCategory
  isActive            Boolean      @default(true)
  createdAt           DateTime     @default(now())

  purchases DropPurchase[]
}

model DropPurchase {
  id            String   @id @default(uuid())
  dropId        String
  userId        String
  editionNumber Int
  purchasedAt   DateTime @default(now())

  drop Drop @relation(fields: [dropId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@unique([dropId, userId])
}

enum SubscriptionTier {
  FREE
  PRO
  PREMIUM
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  TRIALING
}

model Subscription {
  id                   String             @id @default(uuid())
  userId               String             @unique
  tier                 SubscriptionTier   @default(FREE)
  status               SubscriptionStatus @default(ACTIVE)
  stripeCustomerId     String?
  stripeSubscriptionId String?
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model VIPMembership {
  id          String   @id @default(uuid())
  userId      String   @unique
  tier        VIPTier  @default(GOLD)
  invitedAt   DateTime @default(now())
  invitedById String?
  privileges  String[]

  user User @relation(fields: [userId], references: [id])
}

model UserTitle {
  id              String   @id @default(uuid())
  userId          String
  title           String
  earnedCondition String
  isActive        Boolean  @default(false)
  earnedAt        DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, isActive])
}

model UserBrand {
  id           String   @id @default(uuid())
  userId       String   @unique
  colorTheme   String?
  avatarConfig Json?
  monogram     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}
