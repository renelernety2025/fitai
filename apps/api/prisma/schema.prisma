// ─── Section L: Generative Meal Planning ────────────────────────────
// Claude generates a 7-day personalized meal plan based on user goals,
// allergies, dietary preferences, and macro targets. Each plan stores
// the full structured payload (days × meals + shopping list) as JSON
// so we can iterate without schema migrations.

model MealPlan {
  id          String   @id @default(uuid())
  userId      String
  weekStart   DateTime @db.Date // Monday of the week
  generatedAt DateTime @default(now())
  source      String   @default("claude") // claude | rules
  modelUsed   String   @default("claude-haiku-4-5")
  payload     Json // { days: [{date, meals: [{type, name, kcal, protein, carbs, fat, ingredients[], prepMinutes, notes?}]}], shoppingList: [{item, qty, unit, category}], totalKcal, avgProtein, ... }
  notes       String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekStart])
  @@index([userId, weekStart(sort: Desc)])
}

// ─── /Section L ──────────────────────────────────────────────────────

// ─── Section K: Body Progress Photos ─────────────────────────────────
// Private body composition tracking. Photos are user-only by default,
// optional Claude Vision analysis estimates body fat % and visible
// changes vs previous photo of the same angle.

enum PhotoSide {
  FRONT
  SIDE
  BACK
}

model BodyPhoto {
  id         String    @id @default(uuid())
  userId     String
  s3Key      String // s3://fitai-assets-production/progress-photos/{userId}/{id}.jpg
  side       PhotoSide @default(FRONT)
  takenAt    DateTime  @default(now())
  weightKg   Float? // optional metadata at time of photo
  bodyFatPct Float? // user-entered, may be different from analysis
  notes      String?
  isAnalyzed Boolean   @default(false)
  createdAt  DateTime  @default(now())

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  analysis BodyAnalysis?

  @@index([userId, takenAt(sort: Desc)])
  @@index([userId, side, takenAt(sort: Desc)])
}

model BodyAnalysis {
  id                  String   @id @default(uuid())
  bodyPhotoId         String   @unique
  estimatedBodyFatPct Float? // Claude Vision estimate
  estimatedMuscleMass String? // qualitative: "low|moderate|high|elite"
  postureNotes        String? // anterior pelvic tilt, kyphosis, etc.
  visibleStrengths    String[] @default([])
  areasToWork         String[] @default([])
  comparisonNotes     String? // vs previous photo of same angle
  rawClaudeResponse   String? // full text for debugging
  modelUsed           String   @default("claude-haiku-4-5")
  createdAt           DateTime @default(now())

  bodyPhoto BodyPhoto @relation(fields: [bodyPhotoId], references: [id], onDelete: Cascade)
}

