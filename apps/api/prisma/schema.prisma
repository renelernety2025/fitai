// Exercise library expanded to 60 exercises (2026-04-19)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum VideoCategory {
  YOGA
  PILATES
  STRENGTH
  CARDIO
  MOBILITY
}

enum VideoDifficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum PreprocessingStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum MuscleGroup {
  CHEST
  BACK
  SHOULDERS
  BICEPS
  TRICEPS
  QUADRICEPS
  HAMSTRINGS
  GLUTES
  CALVES
  CORE
  FULL_BODY
}

enum WorkoutPlanType {
  PUSH_PULL_LEGS
  UPPER_LOWER
  FULL_BODY
  CUSTOM
}

enum SetStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  SKIPPED
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String
  name          String
  avatarUrl     String?
  bio           String?
  propsReceived Int       @default(0)
  level         UserLevel @default(BEGINNER)
  isAdmin       Boolean   @default(false)
  expoPushToken String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions              WorkoutSession[]
  progress              UserProgress?
  workoutPlans          WorkoutPlan[]
  gymSessions           GymSession[]
  exerciseHistory       ExerciseHistory[]
  coachingSessions      CoachingSession[]
  safetyEvents          SafetyEvent[]
  fitnessProfile        FitnessProfile?
  aiPlans               AIGeneratedPlan[]
  pushSubscriptions     PushSubscription[]
  notificationPrefs     NotificationPreference?
  following             Follow[]                @relation("follower")
  followers             Follow[]                @relation("followed")
  feedItems             ActivityFeedItem[]
  challengeEntries      ChallengeParticipant[]
  wearableData          WearableData[]
  contentImports        ContentImport[]
  marketplaceItems      MarketplaceItem[]
  foodLogs              FoodLog[]
  dailyCheckIns         DailyCheckIn[]
  achievementUnlocks    AchievementUnlock[]
  bodyPhotos            BodyPhoto[]
  mealPlans             MealPlan[]
  journalEntries        JournalEntry[]
  recipes               Recipe[]
  createdChallenges     Challenge[]             @relation("ChallengeCreator")
  leagueMemberships     LeagueMembership[]
  skillUnlocks          SkillUnlock[]
  scheduledWorkouts     ScheduledWorkout[]
  seasonProgress        SeasonProgress[]
  missionCompletions    MissionCompletion[]
  bloodworkEntries      BloodworkEntry[]
  rehabPlans            RehabPlan[]
  streakFreezes         StreakFreeze[]
  marketplaceListings   MarketplaceListing[]    @relation("ListingAuthor")
  marketplacePurchases  MarketplacePurchase[]
  bossAttempts          BossAttempt[]
  gymReviews            GymReview[]
  stories               Story[]
  reactions             Reaction[]
  comments              Comment[]
  buddyProfile          BuddyProfile?
  sentSwipes            BuddySwipe[]            @relation("Swiper")
  sentMessages          DirectMessage[]         @relation("MessageSender")
  conversations1        Conversation[]          @relation("Participant1")
  conversations2        Conversation[]          @relation("Participant2")
  propsGiven            Props[]                 @relation("PropsGiver")
  propsReceiv           Props[]                 @relation("PropsReceiver")
  flashParticipations   FlashParticipant[]
  passwordResets        PasswordResetToken[]
  // Phase 1: Performance Core
  maintenanceSchedules  MaintenanceSchedule[]
  maintenanceAlerts     MaintenanceAlert[]
  coachingMemories      CoachingMemory[]
  // Phase 2: Social Expansion
  duelsAsChallenger     Duel[]                  @relation("DuelChallenger")
  duelsAsChallenged     Duel[]                  @relation("DuelChallenged")
  squadMemberships      SquadMembership[]
  personStreaksA        PersonStreak[]          @relation("PersonStreakA")
  personStreaksB        PersonStreak[]          @relation("PersonStreakB")
  userSupplements       UserSupplement[]
  gearItems             GearItem[]
  gearReviews           GearReview[]
  // Phase 3: Content & UGC
  clips                 Clip[]
  clipLikes             ClipLike[]
  clipComments          ClipComment[]
  duetComparisons       DuetComparison[]
  playlistLinks         PlaylistLink[]
  // Phase 4: Marketplace
  trainerProfile        TrainerProfile?
  trainerReviews        TrainerReview[]
  bookings              Booking[]
  routines              Routine[]
  bundles               Bundle[]
  bundlePurchases       BundlePurchase[]
  dailyQuestCompletions DailyQuestCompletion[]
  wishlistItems         Wishlist[]
  planTrials            PlanTrial[]
  // Phase 5: Exclusivity
  dropPurchases         DropPurchase[]
  vipMembership         VIPMembership?
  userTitles            UserTitle[]
  userBrand             UserBrand?
  subscription          Subscription?
}

model UserProgress {
  id              String    @id @default(uuid())
  userId          String    @unique
  totalXP         Int       @default(0)
  currentStreak   Int       @default(0)
  longestStreak   Int       @default(0)
  lastWorkoutDate DateTime?
  totalSessions   Int       @default(0)
  totalMinutes    Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Video {
  id                  String              @id @default(uuid())
  title               String
  description         String
  category            VideoCategory
  difficulty          VideoDifficulty
  durationSeconds     Int
  thumbnailUrl        String
  hlsUrl              String?
  s3RawKey            String
  choreographyUrl     String?
  preprocessingStatus PreprocessingStatus @default(PENDING)
  preprocessingError  String?
  preprocessingJobId  String?
  isPublished         Boolean             @default(false)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  sessions WorkoutSession[]
}

model WorkoutSession {
  id              String    @id @default(uuid())
  userId          String
  videoId         String?
  gymSessionId    String?   @unique
  startedAt       DateTime  @default(now())
  completedAt     DateTime?
  durationSeconds Int       @default(0)
  accuracyScore   Float     @default(0)
  poseData        Json?

  user       User           @relation(fields: [userId], references: [id])
  video      Video?         @relation(fields: [videoId], references: [id])
  gymSession GymSession?    @relation(fields: [gymSessionId], references: [id])
  snapshots  PoseSnapshot[]

  @@index([userId])
  @@index([videoId])
}

model PoseSnapshot {
  id           String  @id @default(uuid())
  sessionId    String
  timestamp    Int
  poseName     String
  isCorrect    Boolean
  errorMessage String?
  jointAngles  Json

  session WorkoutSession @relation(fields: [sessionId], references: [id])

  @@index([sessionId])
}

// ── Gym / Exercise System ──

model Exercise {
  id             String          @id @default(uuid())
  name           String          @unique
  nameCs         String
  description    String
  descriptionCs  String
  muscleGroups   MuscleGroup[]
  difficulty     VideoDifficulty
  category       String          @default("isolation") // compound | isolation | accessory
  equipment      String[]        @default([]) // [] = bodyweight; barbell, dumbbell, machine, band, kettlebell
  phases         Json
  instructions   Json?
  thumbnailUrl   String?
  instructionUrl String?
  videoUrl       String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  plannedExercises  PlannedExercise[]
  exerciseSets      ExerciseSet[]
  exerciseHistory   ExerciseHistory[]
  coachingMemories  CoachingMemory[]
  clips             Clip[]
  playlistLinks     PlaylistLink[]
  craftmanshipStory CraftmanshipStory?
}

model WorkoutPlan {
  id          String          @id @default(uuid())
  userId      String?
  name        String
  nameCs      String
  description String
  type        WorkoutPlanType
  difficulty  VideoDifficulty
  isTemplate  Boolean         @default(false)
  daysPerWeek Int             @default(3)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  user              User?              @relation(fields: [userId], references: [id])
  days              WorkoutDay[]
  gymSessions       GymSession[]
  aiPlans           AIGeneratedPlan[]
  scheduledWorkouts ScheduledWorkout[]
  planTrials        PlanTrial[]
}

model WorkoutDay {
  id            String   @id @default(uuid())
  workoutPlanId String
  dayIndex      Int
  name          String
  nameCs        String
  createdAt     DateTime @default(now())

  workoutPlan      WorkoutPlan       @relation(fields: [workoutPlanId], references: [id], onDelete: Cascade)
  plannedExercises PlannedExercise[]

  @@unique([workoutPlanId, dayIndex])
}

model PlannedExercise {
  id           String  @id @default(uuid())
  workoutDayId String
  exerciseId   String
  orderIndex   Int
  targetSets   Int
  targetReps   Int
  targetWeight Float?
  restSeconds  Int     @default(90)
  notes        String?
  groupId      String? // shared UUID groups exercises into superset/circuit
  groupType    String? // superset, circuit, giant, drop
  groupOrder   Int? // order within group (0-based)

  workoutDay WorkoutDay @relation(fields: [workoutDayId], references: [id], onDelete: Cascade)
  exercise   Exercise   @relation(fields: [exerciseId], references: [id])

  @@unique([workoutDayId, orderIndex])
}

model GymSession {
  id               String           @id @default(uuid())
  userId           String
  workoutPlanId    String?
  workoutDayIndex  Int?
  coachPersonality CoachPersonality @default(MOTIVATIONAL)
  workoutMode      WorkoutMode      @default(SPORT)
  startedAt        DateTime         @default(now())
  completedAt      DateTime?
  totalReps        Int              @default(0)
  averageFormScore Float            @default(0)
  durationSeconds  Int              @default(0)

  user           User            @relation(fields: [userId], references: [id])
  workoutPlan    WorkoutPlan?    @relation(fields: [workoutPlanId], references: [id])
  workoutSession WorkoutSession?
  exerciseSets   ExerciseSet[]
  journalEntry   JournalEntry?

  @@index([userId])
}

model ExerciseSet {
  id           String    @id @default(uuid())
  gymSessionId String
  exerciseId   String
  setNumber    Int
  targetReps   Int
  actualReps   Int       @default(0)
  targetWeight Float?
  actualWeight Float?
  formScore    Float     @default(0)
  rpe          Int? // Rate of Perceived Exertion 1-10
  isWarmup     Boolean   @default(false)
  tempoSeconds Float? // Average tempo (rep duration)
  status       SetStatus @default(PENDING)
  startedAt    DateTime?
  completedAt  DateTime?
  repData      Json?

  gymSession  GymSession   @relation(fields: [gymSessionId], references: [id], onDelete: Cascade)
  exercise    Exercise     @relation(fields: [exerciseId], references: [id])
  sectorTimes SectorTime[]

  @@index([gymSessionId])
}

model WeeklyVolume {
  id            String   @id @default(uuid())
  userId        String
  weekStart     DateTime
  muscleGroup   String
  totalSets     Int      @default(0)
  totalReps     Int      @default(0)
  totalVolumeKg Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, weekStart, muscleGroup])
  @@index([userId])
}

model ExerciseHistory {
  id           String   @id @default(uuid())
  userId       String
  exerciseId   String
  date         DateTime @default(now())
  bestWeight   Float?
  bestReps     Int
  avgFormScore Float
  totalVolume  Float

  user     User     @relation(fields: [userId], references: [id])
  exercise Exercise @relation(fields: [exerciseId], references: [id])

  @@index([userId, exerciseId])
  @@index([userId, date])
}

// ── Smart Coach System ──

model CoachingSession {
  id            String   @id @default(uuid())
  userId        String
  sessionType   String
  sessionId     String
  title         String?
  messagesCount Int      @default(0)
  tokensUsed    Int      @default(0)
  createdAt     DateTime @default(now())

  user     User              @relation(fields: [userId], references: [id])
  messages CoachingMessage[]

  @@index([userId])
}

model CoachingMessage {
  id                String   @id @default(uuid())
  coachingSessionId String
  role              String
  content           String
  priority          String
  audioUrl          String?
  createdAt         DateTime @default(now())

  coachingSession CoachingSession @relation(fields: [coachingSessionId], references: [id], onDelete: Cascade)

  @@index([coachingSessionId])
}

model SafetyEvent {
  id            String   @id @default(uuid())
  userId        String
  sessionType   String
  sessionId     String
  jointName     String
  measuredAngle Float
  safeMin       Float
  safeMax       Float
  exerciseName  String
  severity      String
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

// ── Workout Journal ──

enum JournalMood {
  GREAT
  GOOD
  NEUTRAL
  TIRED
  BAD
}

model JournalEntry {
  id           String       @id @default(uuid())
  userId       String
  date         DateTime     @db.Date
  gymSessionId String?      @unique
  notes        String?
  rating       Int?
  mood         JournalMood?
  tags         String[]
  measurements Json?
  aiInsight    String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  user       User           @relation(fields: [userId], references: [id])
  gymSession GymSession?    @relation(fields: [gymSessionId], references: [id])
  photos     JournalPhoto[]

  @@unique([userId, date])
  @@index([userId])
}

model JournalPhoto {
  id             String   @id @default(uuid())
  journalEntryId String
  s3Key          String
  caption        String?
  createdAt      DateTime @default(now())

  journalEntry JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)

  @@index([journalEntryId])
}

// ── Adaptive Intelligence ──

enum CoachPersonality {
  DRILL
  CHILL
  MOTIVATIONAL
}

enum FitnessGoal {
  STRENGTH
  HYPERTROPHY
  ENDURANCE
  WEIGHT_LOSS
  GENERAL_FITNESS
  MOBILITY
}

model FitnessProfile {
  id               String      @id @default(uuid())
  userId           String      @unique
  goal             FitnessGoal @default(GENERAL_FITNESS)
  experienceMonths Int         @default(0)
  daysPerWeek      Int         @default(3)
  sessionMinutes   Int         @default(45)
  hasGymAccess     Boolean     @default(true)
  equipment        String[]
  injuries         String[]
  priorityMuscles  String[]    @default([])
  notes            String?
  onboardingDone   Boolean     @default(false)
  age              Int?
  weightKg         Float?
  heightCm         Float?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  user      User        @relation(fields: [userId], references: [id])
  oneRepMax OneRepMax[]

  // Nutrition goals (Section F)
  dailyKcal     Int?
  dailyProteinG Int?
  dailyCarbsG   Int?
  dailyFatG     Int?
}

model Achievement {
  id            String   @id @default(uuid())
  code          String   @unique // first_workout, streak_7, total_100_reps...
  title         String
  titleCs       String
  description   String
  descriptionCs String
  category      String // training, streak, milestone, social, exploration
  icon          String // emoji nebo SVG ref
  xpReward      Int      @default(0)
  threshold     Int? // např. 7 pro streak_7, 100 pro 100 reps
  createdAt     DateTime @default(now())

  unlocks AchievementUnlock[]
}

model AchievementUnlock {
  id            String   @id @default(uuid())
  userId        String
  achievementId String
  unlockedAt    DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id])
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId])
}

model DailyCheckIn {
  id           String   @id @default(uuid())
  userId       String
  date         DateTime @db.Date
  sleepHours   Float? // 0-12
  sleepQuality Int? // 1-5
  hydrationL   Float? // liters of water
  steps        Int?
  mood         Int? // 1-5
  energy       Int? // 1-5 — physical energy
  soreness     Int? // 1-5 — muscle soreness
  stress       Int? // 1-5
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, date])
  @@index([userId, date])
}

model FoodLog {
  id           String   @id @default(uuid())
  userId       String
  date         DateTime @db.Date
  mealType     String // breakfast, lunch, dinner, snack
  name         String
  kcal         Int
  proteinG     Float    @default(0)
  carbsG       Float    @default(0)
  fatG         Float    @default(0)
  servings     Float    @default(1)
  photoS3Key   String?
  source       String? // home, restaurant, store, delivery
  sourceDetail String? // restaurant name, store name, etc.
  ingredients  String? // free-text ingredients list
  recipeId     String?
  rating       Int? // 1-5
  notes        String?
  confidence   Float? // AI confidence 0-1
  createdAt    DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id])
  recipe Recipe? @relation(fields: [recipeId], references: [id])

  @@index([userId, date])
}

model Recipe {
  id             String   @id @default(uuid())
  userId         String
  name           String
  description    String?
  ingredients    Json // [{name, amount, unit}]
  instructions   String?
  prepMinutes    Int?
  cookMinutes    Int?
  servings       Int      @default(1)
  kcalPerServing Int?
  proteinG       Float?
  carbsG         Float?
  fatG           Float?
  photoS3Key     String?
  tags           String[]
  isFavorite     Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id])
  foodLogs FoodLog[]

  @@index([userId])
}

// ── Leagues & Divisions ──

enum LeagueTier {
  BRONZE
  SILVER
  GOLD
  DIAMOND
  LEGEND
}

model LeagueMembership {
  id        String     @id @default(uuid())
  userId    String
  tier      LeagueTier @default(BRONZE)
  weekStart DateTime   @db.Date
  weeklyXP  Int        @default(0)
  rank      Int?
  promoted  Boolean    @default(false)
  relegated Boolean    @default(false)
  createdAt DateTime   @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, weekStart])
  @@index([weekStart, tier])
}

// ── Skill Tree ──

model SkillUnlock {
  id         String   @id @default(uuid())
  userId     String
  skillCode  String
  unlockedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, skillCode])
  @@index([userId])
}

// ── Workout Calendar ──

model ScheduledWorkout {
  id            String   @id @default(uuid())
  userId        String
  date          DateTime @db.Date
  title         String
  workoutPlanId String?
  workoutDayIdx Int?
  notes         String?
  completed     Boolean  @default(false)
  gymSessionId  String?
  createdAt     DateTime @default(now())

  user        User         @relation(fields: [userId], references: [id])
  workoutPlan WorkoutPlan? @relation(fields: [workoutPlanId], references: [id])

  @@index([userId, date])
}

// ── Battle Pass / Seasons ──

model Season {
  id        String   @id @default(uuid())
  name      String
  startDate DateTime @db.Date
  endDate   DateTime @db.Date
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  missions          SeasonMission[]
  playerProgression SeasonProgress[]
}

model SeasonMission {
  id          String @id @default(uuid())
  seasonId    String
  code        String
  titleCs     String
  description String
  type        String // daily, weekly, challenge
  targetValue Int
  xpReward    Int
  orderIndex  Int

  season Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@unique([seasonId, code])
}

model SeasonProgress {
  id        String   @id @default(uuid())
  userId    String
  seasonId  String
  level     Int      @default(1)
  totalXP   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id])
  season Season @relation(fields: [seasonId], references: [id])

  @@unique([userId, seasonId])
}

model MissionCompletion {
  id          String   @id @default(uuid())
  userId      String
  missionId   String
  completedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, missionId])
}

// ── Bloodwork Tracker ──

model BloodworkEntry {
  id           String   @id @default(uuid())
  userId       String
  date         DateTime @db.Date
  testType     String // testosterone, iron, vitaminD, crp, cholesterol, glucose, hba1c
  value        Float
  unit         String
  referenceMin Float?
  referenceMax Float?
  lab          String?
  notes        String?
  aiInsight    String?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, testType, date])
}

// ── Injury Rehab Planner ──

model RehabPlan {
  id         String    @id @default(uuid())
  userId     String
  injuryType String
  bodyPart   String
  severity   String // mild, moderate, severe
  startDate  DateTime  @db.Date
  targetDate DateTime? @db.Date
  status     String    @default("active") // active, completed, paused
  aiPlan     Json? // structured rehab plan from Claude
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user     User           @relation(fields: [userId], references: [id])
  sessions RehabSession[]

  @@index([userId])
}

model RehabSession {
  id          String   @id @default(uuid())
  rehabPlanId String
  date        DateTime @db.Date
  exercises   Json // [{name, sets, reps, notes}]
  painLevel   Int? // 0-10
  notes       String?
  completed   Boolean  @default(false)
  createdAt   DateTime @default(now())

  rehabPlan RehabPlan @relation(fields: [rehabPlanId], references: [id], onDelete: Cascade)

  @@index([rehabPlanId])
}

// ── Streak Freeze ──

model StreakFreeze {
  id        String   @id @default(uuid())
  userId    String
  usedDate  DateTime @db.Date
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, usedDate])
  @@index([userId])
}

// ── Marketplace ──

model MarketplaceListing {
  id          String   @id @default(uuid())
  authorId    String
  title       String
  description String?
  type        String // workout_plan, meal_plan, challenge
  planId      String? // link to WorkoutPlan
  priceXP     Int      @default(0) // 0 = free
  rating      Float    @default(0)
  ratingCount Int      @default(0)
  downloads   Int      @default(0)
  isPublished Boolean  @default(true)
  tags        String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author    User                  @relation("ListingAuthor", fields: [authorId], references: [id])
  purchases MarketplacePurchase[]

  @@index([authorId])
  @@index([type, isPublished])
}

model MarketplacePurchase {
  id         String   @id @default(uuid())
  userId     String
  listingId  String
  xpPaid     Int
  userRating Int?
  createdAt  DateTime @default(now())

  user    User               @relation(fields: [userId], references: [id])
  listing MarketplaceListing @relation(fields: [listingId], references: [id])

  @@unique([userId, listingId])
}

// ── Boss Fights ──

model BossAttempt {
  id          String    @id @default(uuid())
  userId      String
  bossCode    String
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  score       Int       @default(0)
  defeated    Boolean   @default(false)

  user User @relation(fields: [userId], references: [id])

  @@index([userId, bossCode])
}

// ── Gym Finder ──

model GymReview {
  id        String   @id @default(uuid())
  userId    String
  gymName   String
  address   String?
  lat       Float?
  lng       Float?
  rating    Int // 1-5
  equipment String[] // barbells, dumbbells, machines, cables, cardio, etc.
  notes     String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

// ── Social: Stories, Reactions, Comments ──

model Story {
  id           String   @id @default(uuid())
  userId       String
  gymSessionId String?
  cardData     Json
  expiresAt    DateTime
  viewCount    Int      @default(0)
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([expiresAt])
}

model Reaction {
  id         String   @id @default(uuid())
  userId     String
  targetType String // feed_item, story
  targetId   String
