{
  "expo": {
    "name": "FitAI",
    "slug": "fitai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "cz.bfevents.fitai",
      "infoPlist": {
        "NSCameraUsageDescription": "FitAI potřebuje kameru pro real-time pose detection a sledování formy při cvičení.",
        "NSMotionUsageDescription": "FitAI sleduje pohyb pro přesnější počítání opakování.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "cz.bfevents.fitai",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a0a"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "CAMERA",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "FitAI potřebuje kameru pro sledování formy."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#16a34a"
        }
      ],
      "expo-secure-store",
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "FitAI potřebuje kameru pro real-time pose detection a sledování formy při cvičení.",
          "enableMicrophonePermission": false,
          "enableCodeScanner": false
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "bc34dec6-ec92-46fd-8cc0-21e05783214a"
      }
    },
    "owner": "renechlubny"
  }
}
