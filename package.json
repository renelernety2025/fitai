{
  "name": "fitai",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "lint:conventions": "bash scripts/check-api-conventions.sh",
    "lint:docs": "bash scripts/verify-docs-integrity.sh",
    "db:migrate": "cd apps/api && npx prisma migrate dev",
    "db:seed": "cd apps/api && npx prisma db seed",
    "db:studio": "cd apps/api && npx prisma studio"
  },
  "devDependencies": {
    "turbo": "^2.3.0"
  },
  "packageManager": "npm@10.2.0",
  "dependencies": {
    "expo": "~55.0.13",
    "expo-av": "^16.0.8",
    "expo-speech-recognition": "^3.1.2",
    "react": "19.2.0",
    "react-native": "0.83.4"
  },
  "version": "1.0.0"
}
